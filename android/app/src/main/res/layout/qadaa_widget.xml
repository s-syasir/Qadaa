<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/background_light"
    android:padding="8dp">

    <!-- Header: title + streak -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Qadaa"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 0"
            android:textSize="13sp"
            android:textColor="@android:color/black" />
    </LinearLayout>

    <!-- Prayer buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal">

        <!-- Fajr -->
        <LinearLayout
            android:id="@+id/btn_fajr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:padding="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="فجر"
                android:textSize="12sp"
                android:textColor="@android:color/black" />
            <TextView
                android:id="@+id/fajr_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○"
                android:textSize="14sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Dhuhr -->
        <LinearLayout
            android:id="@+id/btn_dhuhr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:padding="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ظهر"
                android:textSize="12sp"
                android:textColor="@android:color/black" />
            <TextView
                android:id="@+id/dhuhr_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○"
                android:textSize="14sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Asr -->
        <LinearLayout
            android:id="@+id/btn_asr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:padding="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عصر"
                android:textSize="12sp"
                android:textColor="@android:color/black" />
            <TextView
                android:id="@+id/asr_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○"
                android:textSize="14sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Maghrib -->
        <LinearLayout
            android:id="@+id/btn_maghrib"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:padding="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مغرب"
                android:textSize="12sp"
                android:textColor="@android:color/black" />
            <TextView
                android:id="@+id/maghrib_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○"
                android:textSize="14sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Isha -->
        <LinearLayout
            android:id="@+id/btn_isha"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:padding="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عشاء"
                android:textSize="12sp"
                android:textColor="@android:color/black" />
            <TextView
                android:id="@+id/isha_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○"
                android:textSize="14sp"
                android:textColor="#888888" />
        </LinearLayout>
    </LinearLayout>

    <!-- Footer: debt -->
    <TextView
        android:id="@+id/widget_debt"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Debt: —"
        android:textSize="11sp"
        android:textColor="#555555" />

</LinearLayout>
